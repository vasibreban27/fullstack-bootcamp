    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-dom": "^4.2.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^4.2.3",
    "globals": "^17.5.0",
    "json-server": "^0.17.4",
    "json-server-auth": "^2.1.0",
